# ============================================================
# longtext2md 配置文件
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- DeepSeek API（主力 LLM）----
# 在 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 经济档位（纠错/摘要/润色），推荐 deepseek-chat（即 V4 Flash）
# 特点：价格极低，1M 上下文窗口
ECONOMY_MODEL=deepseek-chat
ECONOMY_TEMPERATURE=0.1
# 单次最大输出 token 数（V4 Flash 上限 16384）
ECONOMY_MAX_TOKENS=16384

# 高端档位（最终结构化/代码注入），推荐 deepseek-reasoner（即 V4 Pro + thinking）
# 特点：推理链精准，1M 上下文窗口，适合复杂结构化任务
PREMIUM_MODEL=deepseek-reasoner
PREMIUM_TEMPERATURE=0.3
# 单次最大输出 token 数（Pro 模式输出更长推理链）
PREMIUM_MAX_TOKENS=16000

# ---- SiliconFlow API（向量嵌入 + 重排序）----
# 在 https://siliconflow.cn 获取 API Key
# 用于 RAG 检索：ChromaDB 粗排 → SiliconFlow reranker 精排
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 中文嵌入模型，性价比高
EMBEDDING_MODEL=BAAI/bge-m3
# 重排序模型，精排top-k结果
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---- 流水线参数 ----
# 阶段1润色每块最大字符数（超出后在语义边界切分）
MAX_CHUNK_CHARS=2000
# 最大并行任务数（同一时间最多跑几个任务）
MAX_PARALLEL_TASKS=3
# LLM 最大并发调用数（阶段1并行润色上限）
MAX_LLM_CONCURRENCY=50
# LLM 调用失败最大重试次数
LLM_RETRY_MAX=3
# LLM 重试基础延迟（秒），指数退避
LLM_RETRY_BASE_DELAY=1.0
# 所有任务中间产物和最终结果的输出目录
OUTPUT_BASE_DIR=output

# ---- Streamlit GUI ----
# 前端界面端口号
STREAMLIT_PORT=8501
